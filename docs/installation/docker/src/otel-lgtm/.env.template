# =================================================================
# OpenTelemetry LGTM Stack Configuration
# Grafana + Loki (Logs) + Tempo (Traces) + Mimir (Metrics)
# =================================================================

# Grafana Configuration
GRAFANA_PORT=3001
GRAFANA_HTTPS_PORT=3444
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# OpenTelemetry Collector Ports (plaintext — protected by bearer token)
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# OTLP TLS Ports (only published when the `ssl` compose profile is active)
OTEL_HTTPS_PORT=4319
OTEL_GRPCS_PORT=4327

# Bearer token agents must send as `Authorization: Bearer <token>`.
# Auto-generated by the install script. Rotate by replacing this value
# and restarting the otel-lgtm container.
OTEL_INGEST_TOKEN=

# SSL Configuration
OTEL_LGTM_ENABLE_SSL=false
OTEL_LGTM_DOMAIN=localhost

# Component Logging (set to true for verbose logging)
ENABLE_LOGS_ALL=false

# TimescaleDB Connection (for postgres-exporter)
# These should match your TimescaleDB service configuration
TIMESCALEDB_HOST=timescaledb
TIMESCALEDB_DB=timescaledb
TIMESCALEDB_USER=postgres
TIMESCALEDB_PASSWORD=

# MQTT Connection (for mosquitto-exporter)
# These should match your MQTT service configuration
MQTT_HOST=mosquitto
MQTT_USER=
MQTT_PASSWORD=

# Timezone
TZ=UTC

# =================================================================
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Add .env to your .gitignore file
# =================================================================
